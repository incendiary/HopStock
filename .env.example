# Server port (default: 3000)
PORT=3000

# Anthropic API key — enables receipt scanning in the acquisition form
# ANTHROPIC_API_KEY=sk-ant-...

# Auto-backup settings
# BACKUP_INTERVAL_HOURS=24     # How often to run (default: 24). Set to 0 to disable.
# BACKUP_DIR=../backups        # Where to write backup ZIPs (default: ../backups relative to server/)
# BACKUP_KEEP=7                # How many backups to keep (default: 7, oldest pruned automatically)
